{
  "manifest_version": 3,
  "name": "YT Smart Downloader Pro",
  "version": "2.1",
  "description": "ดาวน์โหลดจัดระเบียบพร้อมแสดงสถานะการทำงานแบบ Real-time",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}